# Azure Web PubSub connection string (from Azure Portal > Web PubSub > Keys)
WEB_PUBSUB_CONNECTION_STRING=Endpoint=https://<your-hub>.webpubsub.azure.com;AccessKey=<key>;Version=1.0;

# Comma-separated list of AAD user principal names allowed to connect
ALLOWED_USER_IDS=your@email.com

# Session limits
MAX_SESSION_DURATION_MS=14400000
PTY_COLS=220
PTY_ROWS=50
